rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Productos: lectura pública (para mostrar en menú), escritura autenticada
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Ventas: solo autenticados (datos sensibles)
    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }
    
    // Inventario: solo autenticados (datos internos)
    match /inventory/{itemId} {
      allow read, write: if request.auth != null;
    }
    
    // Gastos: solo autenticados (datos financieros)
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null;
    }
    
    // Tareas: solo autenticados
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
  }
}

