# =============================================================================
# Producción OVH/VPS — copiar a la raíz del proyecto como .env.local
# cp deploy/ovh/env.example ~/arandano/.env.local
# =============================================================================

DB_MODE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

SITE_URL=https://arandanocafe.com
NEXT_PUBLIC_SITE_URL=https://arandanocafe.com
NEXTAUTH_URL=https://arandanocafe.com
AUTH_TRUST_HOST=true

NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FOOTBALL_DATA_API_TOKEN=

# Cuota football-data.org (máx. llamadas/día; catálogo ≈3 por refresh)
FOOTBALL_API_DAILY_LIMIT=100
FOOTBALL_CATALOG_REFRESH_MS=1800000

# Predictor (Google Gemini)
ARI_ENABLED=true
ARI_MODEL=gemini-2.5-flash-lite
ARI_RATE_LIMIT_PER_HOUR=30
GEMINI_API_KEY=

ADMIN_PASSWORD=

NODE_ENV=production
PORT=3000

# Google Console — Authorized redirect URIs (agrega TODAS):
#   http://localhost:3000/api/auth/callback/google
#   https://arandanocafe.com/api/auth/callback/google
#   https://www.arandanocafe.com/api/auth/callback/google
#
# Google Console — Authorized JavaScript origins:
#   http://localhost:3000
#   https://arandanocafe.com
#   https://www.arandanocafe.com
#
# Neon SQL Editor — columnas en MINÚSCULAS (no uses "updatedAt"):
#   SELECT email, displayalias, credits, updatedat FROM sports_users LIMIT 5;
#   npm run check:neon  → verifica conexión desde el servidor
