DB_MODE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
ADMIN_PASSWORD=

NEXTAUTH_URL=https://TU-DOMINIO.com
NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FOOTBALL_DATA_API_TOKEN=

NODE_ENV=production
PORT=3000

# Alternativa local en el servidor: DB_MODE=sqlite y data/arandano.db
# PM2 (ecosystem.config.js) define PROJECT_ROOT y DATA_DIR.
