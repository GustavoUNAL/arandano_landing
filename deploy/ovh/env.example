# Configuración de Variables de Entorno - Arándano Café Bar
# Copia este archivo a .env.local en el directorio raíz del proyecto
# cp deploy/ovh/env.example .env.local

# ============================================
# Database Mode
# ============================================
# Opciones: 'json', 'firebase', 'hybrid'
# Para producción usar: 'firebase'
DB_MODE=firebase

# ============================================
# Firebase Configuration (Cliente)
# ============================================
# Obtener estos valores desde Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=tu_api_key_aqui
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu_proyecto_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=tu_app_id

# ============================================
# Firebase Service Account
# ============================================
# OPCIÓN 1: Usar archivo (Recomendado)
# Coloca firebase-service-account.json en el directorio raíz del proyecto

# OPCIÓN 2: Usar variable de entorno
# Descomenta y pega el JSON completo del service account
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ============================================
# Admin Configuration
# ============================================
# Contraseña para acceso al área de administración
ADMIN_PASSWORD=tu_password_seguro_aqui

# ============================================
# Environment
# ============================================
# No cambiar en producción
NODE_ENV=production

# ============================================
# Server Configuration (Opcional)
# ============================================
# Puerto donde corre la aplicación Next.js
# PORT=3000

# ============================================
# Notas
# ============================================
# 1. NUNCA subas este archivo con valores reales a Git
# 2. El archivo .env.local está en .gitignore
# 3. En producción, considera usar variables de entorno del sistema
# 4. Para obtener el Service Account:
#    Firebase Console > Project Settings > Service Accounts > Generate New Private Key

