# =============================================================================
# Arándano Café Bar — Variables de entorno
# Copiar a .env.local:  cp .env.example .env.local
# =============================================================================

# --- Base de datos ---
DB_MODE=sqlite
# Rutas (opcional; PM2 las define en producción vía ecosystem.config.js)
# PROJECT_ROOT=/ruta/al/proyecto
# DATA_DIR=/ruta/al/proyecto/data
# DATABASE_PATH=/ruta/al/proyecto/data/arandano.db

# --- Panel admin interno ---
ADMIN_PASSWORD=

# --- NextAuth (polla / perfil con Google) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- Google OAuth ---
# https://console.cloud.google.com/apis/credentials
# Redirect URIs autorizadas:
#   http://localhost:3000/api/auth/callback/google
#   https://TU-DOMINIO.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Mundial 2026 (football-data.org) ---
# https://www.football-data.org/documentation/quickstart
FOOTBALL_DATA_API_TOKEN=

# --- Servidor (producción) ---
# NODE_ENV=production
# PORT=3000
