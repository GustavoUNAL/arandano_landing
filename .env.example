# Base de datos — PostgreSQL en Neon (recomendado)
DB_MODE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Alternativa local: SQLite (sin DATABASE_URL)
# DB_MODE=sqlite

# NextAuth (inicio de sesión con Google)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-un-secreto-aleatorio-largo

# Google OAuth — https://console.cloud.google.com/apis/credentials
# URI de redirección: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# football-data.org API — https://www.football-data.org/
FOOTBALL_DATA_API_TOKEN=tu-token
