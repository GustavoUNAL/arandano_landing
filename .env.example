# =============================================================================
# Secretos compartidos — copiar a .env (gitignored)
# =============================================================================

DB_MODE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

NEXTAUTH_SECRET=genera-un-secreto-aleatorio-largo

# Google OAuth — https://console.cloud.google.com/apis/credentials
# URIs de redirección autorizadas:
#   http://localhost:3000/api/auth/callback/google
#   https://arandanocafe.com/api/auth/callback/google
#   https://www.arandanocafe.com/api/auth/callback/google
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

FOOTBALL_DATA_API_TOKEN=tu-token

# =============================================================================
# URLs por entorno (ya incluidas en .env.development y .env.production)
# =============================================================================
# Desarrollo:  .env.development  → http://localhost:3000
# Producción:  .env.production   → https://arandanocafe.com
# Servidor:    .env.local        → copiar desde deploy/ovh/env.production
