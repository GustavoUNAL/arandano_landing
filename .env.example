# =============================================================================
# Desarrollo local — copiar a .env.local (gitignored)
# Crear también .env.development.local con URLs localhost (ver abajo).
# =============================================================================

# Polla sincronizada local ↔ servidor: usa Neon (misma URL en ambos entornos)
DB_MODE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Solo desarrollo offline sin nube (datos NO se sincronizan con producción):
# DB_MODE=sqlite

# --- .env.development.local (npm run dev) ---
# SITE_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000
# AUTH_TRUST_HOST=false

# --- .env.local en servidor (producción) ---
# SITE_URL=https://arandanocafe.com
# NEXTAUTH_URL=https://arandanocafe.com
# AUTH_TRUST_HOST=true

NEXTAUTH_SECRET=genera-un-secreto-aleatorio-largo

GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

FOOTBALL_DATA_API_TOKEN=tu-token
FOOTBALL_API_DAILY_LIMIT=100
FOOTBALL_CATALOG_REFRESH_MS=1800000

# api-football.com v3 (cuenta Pro) — https://www.api-football.com
# Obtener en: https://dashboard.api-football.com → My account → API Keys
API_FOOTBALL_KEY=tu-api-football-key

# Predictor (Google Gemini) — no commitear la clave real
ARI_ENABLED=true
ARI_MODEL=gemini-2.5-flash-lite
ARI_RATE_LIMIT_PER_HOUR=30
GEMINI_API_KEY=tu-clave-gemini

# Admin polla (emails separados por coma). Por defecto: gustavoarteaga0508@gmail.com
# POLL_ADMIN_EMAIL=gustavoarteaga0508@gmail.com

# =============================================================================
# Producción en servidor: deploy/ovh/env.example → ~/arandano/.env.local
# Misma DATABASE_URL que en local para compartir la polla en la nube.
# =============================================================================
